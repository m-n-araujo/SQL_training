<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="SQL Training - Interactive SQL learning platform with pedagogical framework">
    <meta name="theme-color" content="#0c0a07">
    <title>SQL Training - Beginner to Expert</title>
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300..900&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    
    <style>
        /* ═══════════════════════════════════════════════════════
           DESIGN TOKENS & COLORS
           ═══════════════════════════════════════════════════════ */
        :root {
            --bg: #0c0a07;
            --surf: #131008;
            --s2: #1b1610;
            --s3: #232019;
            --s4: #2c2818;
            --brd: #342e1a;
            --brd-f: #1e1a0e;
            --tx: #ede0c0;
            --t2: #b89555;
            --t3: #6b5530;
            --t4: #3c2e14;
            --amber: #e8a020;
            --amber-light: #f5be50;
            --amber-dark: #7a4c00;
            --sage: #6db870;
            --sage-dark: #163010;
            --terra: #c05840;
            --terra-dark: #481408;
            --mauve: #9870c0;
            --mauve-dark: #281040;
            --steel: #5a9fc0;
            --steel-dark: #102838;
        }

        /* ═══════════════════════════════════════════════════════
           GLOBAL STYLES
           ═══════════════════════════════════════════════════════ */
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html, body {
            height: 100%;
            background: var(--bg);
            color: var(--tx);
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        body {
            font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            line-height: 1.5;
        }

        /* Scrollbar */
        ::-webkit-scrollbar {
            width: 4px;
            height: 4px;
        }

        ::-webkit-scrollbar-track {
            background: var(--bg);
        }

        ::-webkit-scrollbar-thumb {
            background: var(--brd);
            border-radius: 2px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: var(--t3);
        }

        /* Form Elements */
        textarea, input, select {
            font-family: 'JetBrains Mono', 'Monaco', monospace;
        }

        textarea:focus, input:focus, select:focus {
            outline: none;
        }

        button {
            cursor: pointer;
            font-family: 'Plus Jakarta Sans', sans-serif;
            transition: all 0.2s ease;
        }

        button:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        /* ═══════════════════════════════════════════════════════
           ANIMATIONS
           ═══════════════════════════════════════════════════════ */
        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(14px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes glow {
            0%, 100% {
                box-shadow: 0 0 8px rgba(232, 160, 32, 0.2);
            }
            50% {
                box-shadow: 0 0 20px rgba(232, 160, 32, 0.35);
            }
        }

        @keyframes pulse {
            0%, 100% {
                opacity: 1;
            }
            50% {
                opacity: 0.4;
            }
        }

        @keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        .aUp {
            animation: slideUp 0.3s cubic-bezier(0.22, 0.68, 0, 1.15) both;
        }

        /* ═══════════════════════════════════════════════════════
           LAYOUT
           ═══════════════════════════════════════════════════════ */
        #root {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .app {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            background: var(--bg);
        }

        .app-header {
            background: var(--surf);
            border-bottom: 1px solid var(--brd);
            height: 52px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 18px;
            flex-shrink: 0;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .app-main {
            flex: 1;
            overflow-y: auto;
            padding: 28px;
            max-width: 860px;
            width: 100%;
            margin: 0 auto;
            align-self: stretch;
        }

        .app-bottom {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            height: 36px;
            background: var(--surf);
            border-top: 1px solid var(--brd);
            display: flex;
            align-items: center;
            padding: 0 16px;
            gap: 8px;
            z-index: 200;
            font-size: 11px;
        }

        /* ═══════════════════════════════════════════════════════
           STATUS INDICATORS
           ═══════════════════════════════════════════════════════ */
        .status-indicator {
            display: inline-block;
            width: 6px;
            height: 6px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        .status-loading {
            background: var(--amber);
            animation: pulse 1.5s ease infinite;
        }

        .status-ready {
            background: var(--sage);
            animation: glow 2s ease-in-out infinite;
        }

        .status-error {
            background: var(--terra);
        }

        /* ═══════════════════════════════════════════════════════
           ERROR STYLES
           ═══════════════════════════════════════════════════════ */
        .error-box {
            padding: 20px;
            background: #1e0808;
            border: 1px solid #4c1818;
            border-radius: 8px;
            color: #e07070;
            margin: 20px 0;
        }

        .error-box h2 {
            margin-bottom: 10px;
            font-family: 'Fraunces', serif;
            font-size: 18px;
        }

        /* ═══════════════════════════════════════════════════════
           RESPONSIVE
           ═══════════════════════════════════════════════════════ */
        @media (max-width: 640px) {
            .hide-sm {
                display: none !important;
            }
            .sm-col {
                flex-direction: column !important;
            }
            .sm-full {
                width: 100% !important;
            }
            .app-main {
                padding: 18px 14px 40px;
            }
        }

        @media (max-width: 900px) {
            .hide-md {
                display: none !important;
            }
            .md-col {
                flex-direction: column !important;
            }
        }
    </style>
</head>
<body>
    <div id="root"></div>

    <!-- External Libraries -->
    <script crossorigin src="https://unpkg.com/react@17/umd/react.development.js"></script>
    <script crossorigin src="https://unpkg.com/react-dom@17/umd/react-dom.development.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/sql.js/1.6.2/sql-wasm.js"></script>

    <!-- Application -->
    <script type="text/babel">
        const { useState, useEffect, useRef, useCallback, useMemo, useReducer } = React;

        /* ═══════════════════════════════════════════════════════
           CONSTANTS & CONFIGURATION
           ═══════════════════════════════════════════════════════ */
        const T = {
            bg: "#0c0a07", surf: "#131008", s2: "#1b1610", s3: "#232019", s4: "#2c2818",
            brd: "#342e1a", brdF: "#1e1a0e",
            tx: "#ede0c0", t2: "#b89555", t3: "#6b5530", t4: "#3c2e14",
            A: "#e8a020", AL: "#f5be50", AD: "#7a4c00",
            S: "#6db870", SD: "#163010",
            R: "#c05840", RD: "#481408",
            M: "#9870c0", MD: "#281040",
            B: "#5a9fc0", BD: "#102838",
            ok: { bg: "#0b1e0e", brd: "#1a4020", tx: "#6dcc88" },
            err: { bg: "#1e0808", brd: "#4c1818", tx: "#e07070" },
            warn: { bg: "#1e1408", brd: "#4c2e08", tx: "#e0a050" },
        };

        const LC = ["#6db870", "#e8a020", "#c05840", "#9870c0"];
        const DIFF = { Easy: T.S, Medium: T.A, Hard: T.R, Expert: T.M };
        const TC = { employees: T.B, departments: T.S, products: T.M, customers: T.A, orders: T.R };
        
        const SCHEMA_MAP = {
            employees: ["id", "name", "dept_id", "salary", "hire_date", "manager_id"],
            departments: ["id", "name", "city", "budget"],
            products: ["id", "name", "category", "price", "stock"],
            customers: ["id", "name", "email", "city"],
            orders: ["id", "customer_id", "product_id", "qty", "order_date"],
        };

        const CO = {
            nexus: { name: "Nexus Commerce", icon: "🛒", color: T.A, role: "Data Analyst, Growth", note: "E-commerce marketplace, 450 employees" },
            meridian: { name: "Meridian Health", icon: "🏥", color: T.S, role: "People Analytics Analyst, HR", note: "Regional hospital network, 2,800 employees" },
            atlas: { name: "Atlas Capital", icon: "📊", color: T.M, role: "BI Analyst, Finance", note: "Investment advisory, 320 employees" },
            forge: { name: "Forge Logistics", icon: "📦", color: T.R, role: "Operations Analyst, Supply Chain", note: "3PL provider, 1,200 employees" },
        };

        /* ═══════════════════════════════════════════════════════
           UTILITY FUNCTIONS
           ═══════════════════════════════════════════════════════ */
        const sanitizeHTML = (text) => {
            if (!text) return "";
            return text
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;");
        };

        const useWindowSize = () => {
            const [width, setWidth] = useState(typeof window !== "undefined" ? window.innerWidth : 1200);
            useEffect(() => {
                const handleResize = () => setWidth(window.innerWidth);
                window.addEventListener("resize", handleResize);
                return () => window.removeEventListener("resize", handleResize);
            }, []);
            return width;
        };

        /* ═══════════════════════════════════════════════════════
           ERROR BOUNDARY
           ═══════════════════════════════════════════════════════ */
        class ErrorBoundary extends React.Component {
            constructor(props) {
                super(props);
                this.state = { hasError: false, error: null };
            }

            static getDerivedStateFromError(error) {
                return { hasError: true, error };
            }

            componentDidCatch(error, errorInfo) {
                console.error("ErrorBoundary caught:", error, errorInfo);
            }

            render() {
                if (this.state.hasError) {
                    return (
                        <div className="error-box" role="alert">
                            <h2>⚠️ Something went wrong</h2>
                            <p>{this.state.error?.message || "An unexpected error occurred"}</p>
                            <button 
                                onClick={() => this.setState({ hasError: false })}
                                style={{
                                    marginTop: 10,
                                    padding: "8px 16px",
                                    background: T.A,
                                    color: T.bg,
                                    border: "none",
                                    borderRadius: 6,
                                    fontWeight: 600
                                }}
                                aria-label="Try again"
                            >
                                Try Again
                            </button>
                        </div>
                    );
                }
                return this.props.children;
            }
        }

        /* ═══════════════════════════════════════════════════════
           MEMOIZED PRIMITIVE COMPONENTS
           ═══════════════════════════════════════════════════════ */
        const Tag = React.memo(({ label, color, sm }) => (
            <span style={{
                display: "inline-flex",
                alignItems: "center",
                padding: sm ? "1px 7px" : "2px 10px",
                borderRadius: 99,
                fontSize: sm ? 9.5 : 11,
                fontWeight: 600,
                color,
                background: `${color}22`,
            }}>
                {label}
            </span>
        ));

        const Button = React.memo(({ children, onClick, primary, color, disabled, style }) => {
            const c = color || T.A;
            return (
                <button
                    onClick={onClick}
                    disabled={disabled}
                    style={{
                        padding: "10px 22px",
                        borderRadius: 9,
                        border: primary ? `2px solid ${c}` : `1px solid ${T.brd}`,
                        background: primary ? c : T.s2,
                        color: primary ? T.bg : T.t2,
                        fontWeight: primary ? 700 : 600,
                        ...style
                    }}
                    aria-label={typeof children === 'string' ? children : undefined}
                >
                    {children}
                </button>
            );
        });

        const ProgressBar = React.memo(({ percentage, color, height = 4 }) => (
            <div style={{ background: T.s3, borderRadius: 99, height, overflow: "hidden", flex: 1, maxWidth: 200 }}>
                <div style={{
                    width: `${Math.max(0, Math.min(100, percentage))}%`,
                    height: "100%",
                    background: color,
                    transition: "width 0.3s ease",
                    borderRadius: 99
                }} />
            </div>
        ));

        const Ring = React.memo(({ pct, color, size = 36, sw = 3 }) => {
            const r = (size - sw * 2) / 2;
            const c = 2 * Math.PI * r;
            const d = (pct / 100) * c;
            return (
                <svg width={size} height={size} style={{ transform: "rotate(-90deg)", flexShrink: 0 }}>
                    <circle cx={size / 2} cy={size / 2} r={r} fill="none" stroke={`${color}40`} strokeWidth={sw} />
                    <circle cx={size / 2} cy={size / 2} r={r} fill="none" stroke={color} strokeWidth={sw}
                        strokeDasharray={d} strokeDashoffset={0} strokeLinecap="round" />
                </svg>
            );
        });

        /* ═══════════════════════════════════════════════════════
           DATABASE INITIALIZATION
           ═══════════════════════════════════════════════════════ */
        const initializeDatabase = async () => {
            try {
                if (window.initSqlJs) {
                    const SQL = await window.initSqlJs();
                    const db = new SQL.Database();
                    
                    // Create tables
                    db.run(`
                        CREATE TABLE departments (id INT PRIMARY KEY, name TEXT, city TEXT, budget REAL);
                        CREATE TABLE employees (id INT PRIMARY KEY, name TEXT, dept_id INT, salary REAL, hire_date TEXT, manager_id INT);
                        CREATE TABLE products (id INT PRIMARY KEY, name TEXT, category TEXT, price REAL, stock INT);
                        CREATE TABLE customers (id INT PRIMARY KEY, name TEXT, email TEXT, city TEXT);
                        CREATE TABLE orders (id INT PRIMARY KEY, customer_id INT, product_id INT, qty INT, order_date TEXT);
                    `);

                    // Insert sample data
                    db.run(`
                        INSERT INTO departments VALUES (1, 'Engineering', 'San Francisco', 900000);
                        INSERT INTO departments VALUES (2, 'Marketing', 'New York', 400000);
                        INSERT INTO departments VALUES (3, 'HR', 'Chicago', 260000);
                        INSERT INTO departments VALUES (4, 'Finance', 'New York', 480000);
                        INSERT INTO departments VALUES (5, 'Design', 'San Francisco', 350000);
                        
                        INSERT INTO employees VALUES (1, 'David Kim', 1, 110000, '2018-05-10', NULL);
                        INSERT INTO employees VALUES (2, 'Sarah Chen', 2, 95000, '2019-02-20', NULL);
                        INSERT INTO employees VALUES (3, 'Marcus Webb', 5, 85000, '2020-06-15', NULL);
                        INSERT INTO employees VALUES (4, 'Priya Sharma', 4, 105000, '2017-12-01', NULL);
                    `);

                    return db;
                }
            } catch (error) {
                console.error("Database initialization failed:", error);
                throw error;
            }
        };

        /* ═══════════════════════════════════════════════════════
           MAIN APPLICATION
           ═══════════════════════════════════════════════════════ */
        const App = () => {
            const [db, setDb] = useState(null);
            const [dbErr, setDbErr] = useState(null);
            const [loading, setLoading] = useState(true);
            const winW = useWindowSize();
            const isSm = winW < 640;

            useEffect(() => {
                const setup = async () => {
                    try {
                        setLoading(true);
                        const database = await initializeDatabase();
                        setDb(database);
                    } catch (error) {
                        setDbErr(error.message);
                    } finally {
                        setLoading(false);
                    }
                };

                setup();
            }, []);

            // Keyboard shortcuts
            useEffect(() => {
                const handleKeyPress = (e) => {
                    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
                        e.preventDefault();
                        // Open command palette
                    }
                };

                window.addEventListener('keydown', handleKeyPress);
                return () => window.removeEventListener('keydown', handleKeyPress);
            }, []);

            return (
                <ErrorBoundary>
                    <div className="app">
                        {/* Header */}
                        <header className="app-header" role="banner">
                            <div style={{ display: "flex", alignItems: "center", gap: 10, flexShrink: 0 }}>
                                <div style={{
                                    width: 33,
                                    height: 33,
                                    borderRadius: 8,
                                    background: `linear-gradient(135deg, ${T.A}, ${T.R})`,
                                    display: "flex",
                                    alignItems: "center",
                                    justifyContent: "center",
                                    boxShadow: `0 2px 12px rgba(232, 160, 32, 0.2)`
                                }}>
                                    <span style={{
                                        fontFamily: "'Fraunces', serif",
                                        fontWeight: 900,
                                        fontSize: 17,
                                        color: T.bg,
                                        lineHeight: 1
                                    }}>S</span>
                                </div>
                                {!isSm && (
                                    <div>
                                        <div style={{
                                            fontFamily: "'Fraunces', serif",
                                            fontWeight: 700,
                                            fontSize: 15,
                                            color: T.tx,
                                            letterSpacing: "-0.3px",
                                        }}>SQL Mastery</div>
                                        <div style={{
                                            fontSize: 8.5,
                                            color: T.t3,
                                            letterSpacing: "0.8px",
                                            textTransform: "uppercase",
                                        }}>Beginner → Expert</div>
                                    </div>
                                )}
                            </div>

                            {/* DB Status */}
                            <div style={{
                                display: "flex",
                                alignItems: "center",
                                gap: 5,
                                padding: "4px 10px",
                                background: T.s2,
                                borderRadius: 99,
                                border: `1px solid ${T.brd}`
                            }}>
                                <div 
                                    className={`status-indicator ${loading ? 'status-loading' : db ? 'status-ready' : 'status-error'}`}
                                    role="status"
                                    aria-label={`Database ${loading ? 'loading' : db ? 'ready' : 'error'}`}
                                />
                                {!isSm && (
                                    <span style={{ fontSize: 11, color: T.t2 }}>
                                        {loading ? "Loading…" : db ? "SQLite ready" : "Error"}
                                    </span>
                                )}
                            </div>
                        </header>

                        {/* Main Content */}
                        <main className="app-main" role="main">
                            <section style={{ textAlign: "center", padding: "40px 20px" }}>
                                <h1 style={{
                                    fontFamily: "'Fraunces', serif",
                                    fontSize: isSm ? 28 : 42,
                                    fontWeight: 800,
                                    marginBottom: 12,
                                    color: T.tx,
                                    lineHeight: 1.15,
                                    letterSpacing: "-0.4px"
                                }}>SQL Training Platform</h1>
                                
                                <p style={{
                                    fontSize: 16,
                                    color: T.t2,
                                    marginBottom: 30,
                                    maxWidth: 600,
                                    lineHeight: 1.6,
                                    margin: "0 auto 30px"
                                }}>
                                    Learn SQL through interactive lessons designed with Gradual Release of Responsibility, Spaced Retrieval Practice, and Cognitive Load Theory.
                                </p>

                                <div style={{
                                    display: "grid",
                                    gridTemplateColumns: "repeat(auto-fit, minmax(250px, 1fr))",
                                    gap: 20,
                                    marginBottom: 40
                                }}>
                                    {[
                                        { icon: "✦", title: "Beginner", modules: 3, desc: "SELECT, WHERE, GROUP BY", color: LC[0] },
                                        { icon: "◈", title: "Intermediate", modules: 2, desc: "JOINs, Subqueries", color: LC[1] },
                                        { icon: "❖", title: "Advanced", modules: 4, desc: "Window Functions, CTEs", color: LC[2] }
                                    ].map((level, i) => (
                                        <div 
                                            key={i} 
                                            style={{
                                                padding: 20,
                                                background: T.surf,
                                                border: `1px solid ${T.brd}`,
                                                borderRadius: 10,
                                                transition: "border-color 0.2s, transform 0.2s"
                                            }}
                                            onMouseEnter={(e) => {
                                                e.currentTarget.style.borderColor = level.color;
                                                e.currentTarget.style.transform = "translateY(-2px)";
                                            }}
                                            onMouseLeave={(e) => {
                                                e.currentTarget.style.borderColor = T.brd;
                                                e.currentTarget.style.transform = "translateY(0)";
                                            }}
                                        >
                                            <div style={{ fontSize: 40, marginBottom: 10 }}>{level.icon}</div>
                                            <h3 style={{
                                                fontSize: 18,
                                                fontWeight: 600,
                                                color: T.tx,
                                                marginBottom: 4
                                            }}>{level.title}</h3>
                                            <p style={{
                                                fontSize: 12,
                                                color: T.t3,
                                                marginBottom: 12
                                            }}>{level.modules} modules</p>
                                            <p style={{ fontSize: 14, color: T.t3 }}>{level.desc}</p>
                                        </div>
                                    ))}
                                </div>

                                <div style={{
                                    padding: 20,
                                    background: T.s2,
                                    border: `1px solid ${T.brd}`,
                                    borderRadius: 10,
                                    marginBottom: 30,
                                    textAlign: "left"
                                }}>
                                    <h2 style={{ color: T.A, marginBottom: 15, fontSize: 18 }}>🚀 Key Features</h2>
                                    <ul style={{
                                        listStyle: "none",
                                        color: T.t2,
                                        lineHeight: 1.8,
                                        fontSize: 14
                                    }}>
                                        {[
                                            "Real-world business scenarios with company personas",
                                            "Interactive SQL console with live execution",
                                            "Scaffolded practice exercises with fading support",
                                            "Multiple-choice retrieval practice for retention",
                                            "Responsive design for mobile and desktop",
                                            "Accessible components with ARIA labels",
                                            "Error boundaries for graceful error handling",
                                            "Memoized components for optimal performance"
                                        ].map((feature, i) => (
                                            <li key={i} style={{ marginBottom: 8 }}>
                                                <span style={{ color: T.A, marginRight: 8 }}>✓</span>
                                                {feature}
                                            </li>
                                        ))}
                                    </ul>
                                </div>

                                {loading ? (
                                    <div style={{ color: T.t3, fontSize: 14 }}>
                                        <p style={{ marginBottom: 15 }}>Initializing database...</p>
                                        <div style={{
                                            display: "inline-block",
                                            width: 30,
                                            height: 30,
                                            borderRadius: "50%",
                                            border: `2px solid ${T.brd}`,
                                            borderTopColor: T.A,
                                            animation: "spin 1s linear infinite"
                                        }} />
                                    </div>
                                ) : dbErr ? (
                                    <div className="error-box" role="alert">
                                        <h3>Database Error</h3>
                                        <p>{dbErr}</p>
                                    </div>
                                ) : (
                                    <Button primary color={T.A}>
                                        Start Learning →
                                    </Button>
                                )}
                            </section>
                        </main>

                        {/* Footer */}
                        <div className="app-bottom" role="contentinfo">
                            <span style={{
                                fontFamily: "'JetBrains Mono', monospace",
                                color: T.t3,
                                fontSize: 10.5,
                                marginRight: 12
                            }}>
                                {loading ? "⏳" : db ? "● SQLite" : dbErr ? "⚠" : "○"}
                            </span>
                            <ProgressBar percentage={db ? 100 : loading ? 50 : 0} color={T.A} height={3} />
                            <div style={{ flex: 1 }} />
                            <p style={{
                                fontSize: 11,
                                color: T.t2,
                                margin: 0
                            }}>
                                SQL Training © 2026 • Pedagogically Designed Learning
                            </p>
                        </div>
                    </div>
                </ErrorBoundary>
            );
        };

        /* ═══════════════════════════════════════════════════════
